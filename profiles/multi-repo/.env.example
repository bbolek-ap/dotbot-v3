# Azure DevOps
# PAT with Code (Read/Write), Packaging (Read) scopes
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/YOUR_ORG

# Atlassian
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_CLOUD_ID=
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# NuGet feed authentication
# Azure DevOps PAT with Packaging > Read scope
# NUGET_FEED_VAR: the environment variable name your nuget.config expects (e.g. my-nuget-token)
# NUGET_FEED_PAT: the PAT value. If the Machine-level var is already set, leave blank.
NUGET_FEED_VAR=
NUGET_FEED_PAT=
